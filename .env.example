# Waitlist storage (optional in development).
#
# Leave these unset locally and signups are appended to ./data/waitlist.jsonl.
# In production, create a Supabase project and a `waitlist` table, then set:
#
#   SUPABASE_URL=https://<your-project-ref>.supabase.co
#   SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>
#
# The service role key is secret — set it only as a server-side env var
# (e.g. in Vercel project settings), never expose it to the browser.

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
