# Waitlist endpoint — the Google Apps Script Web App URL bound to the Sheet.
#
# A default live endpoint is baked into lib/config.ts, so you usually don't need
# to set this. Override it here (local) or as a GitHub Actions repo variable
# named WAITLIST_ENDPOINT (CI) to point signups at a different Sheet/backend.
NEXT_PUBLIC_WAITLIST_ENDPOINT=

# Supabase project the waitlist also writes to (in addition to the Sheet above).
# Find these in Supabase → Project Settings → API. The anon/public key is safe to
# expose in the browser bundle; Row Level Security is what protects the table.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Base path the site is served under. Leave empty for local dev.
# CI sets this to /coolfashionappweb for GitHub Pages.
NEXT_PUBLIC_BASE_PATH=
